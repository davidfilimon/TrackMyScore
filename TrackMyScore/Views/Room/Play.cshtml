@{
    List<Room> roomList = new List<Room>();
}

<div class="createGame">
    <a class="btn-dark btn" asp-action="Create" asp-controller="Room">
        Create a room
    </a>
</div>

<div class="searchGame">
    <a class="btn-dark btn" asp-action="RoomList" asp-controller="Room">
        Join an existing room
    </a>
</div>

<div class="createTournament">
    <a class="btn-dark btn" asp-action="Create" asp-controller="Tournament">
        Create a tournament
    </a>
</div>

<div class="searchTournament">
    <a class="btn-dark btn" asp-action="Join" asp-controller="Tournament">
        Join an existing tournament
    </a>
</div>
